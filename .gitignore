# ==============================================================================
# SMART-ECOMMERCE AI SYSTEM - Monorepo .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. OS & Environments
# ------------------------------------------------------------------------------
# System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Global Environment Variables
.env
.env.*
!.env.example
!.env.template

# ------------------------------------------------------------------------------
# 2. IDEs & Editors
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.project
.settings/

# ------------------------------------------------------------------------------
# 3. Node.js (Express Backend & Shared Libs)
# ------------------------------------------------------------------------------
# Dependencies
node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log
pnpm-debug.log*
lerna-debug.log

# Build & Output
dist/
build/
out/
lib/
*.tsbuildinfo

# Coverage
coverage/
.nyc_output/

# ------------------------------------------------------------------------------
# 4. Next.js Frontend (apps/web/)
# ------------------------------------------------------------------------------
# Next.js specific build directories
.next/
out/

# Vercel specific
.vercel/

# ------------------------------------------------------------------------------
# 5. Python (FastAPI / AI-Service / apps/ai-service/)
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
# environments
.env.python
.venv/
venv/
ENV/
env.bak/
venv.bak/

# Jupyter Notebook
.ipynb_checkpoints

# pytest
.pytest_cache/

# FastAPI / Celery / AI specific artifacts
*.model
*.pkl
*.h5
*.weights
ml-runs/
celerybeat-schedule
celerybeat.pid

# ------------------------------------------------------------------------------
# 6. Global Artifacts & Logs
# ------------------------------------------------------------------------------
*.log
logs/
temp/
tmp/
.temp/

# Ignore AI agent command histories if applicable
.claude/history/
