# ── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/smart-ecommerce
MONGODB_DB_NAME=smart-ecommerce

# ── Cloudflare R2 (model artifact storage) ─────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=models

# ── FastAPI service URL (for hot-reload trigger) ────────────────────────────
FASTAPI_URL=http://localhost:8000
INTERNAL_SECRET=change-me-to-a-random-secret

# ── Placement alpha weights (CF vs CBF blend) ───────────────────────────────
# homepage: 0.7 = 70% CF, 30% CBF
# pdp: 0.3 = 30% CF, 70% CBF (similar items)
# cart: 0.5 = balanced
ALPHA_HOMEPAGE=0.7
ALPHA_PDP=0.3
ALPHA_CART=0.5
