# Backend Environment Variables Template
# Copy file này thành .env và điền giá trị thực

# ============================================================
# SERVER
# ============================================================
PORT=5000
# URL của frontend (dùng để CORS whitelist)
CLIENT_URL=http://localhost:5173

# ============================================================
# DATABASE — MongoDB
# ============================================================
# Local dev
MONGO_URI=mongodb://localhost:27017/smart-ecommerce
# Hoặc MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart-ecommerce

# ============================================================
# AUTHENTICATION — JWT
# ============================================================
# Bắt buộc: random string mạnh >= 32 ký tự
# Generate: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# Token expiry duration (7d = 7 ngày)
JWT_EXPIRE=7d

# ============================================================
# AI SERVICE — FastAPI Connection
# ============================================================
# URL của FastAPI service (local dev hoặc Render.com URL)
FASTAPI_URL=http://localhost:8000
# Secret key để gọi /internal/reload-model (phải khớp với AI service)
INTERNAL_SECRET=change-me-to-a-random-secret

# ============================================================
# AI — OpenRouter
# ============================================================
# Lấy từ: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_ENABLED=true
# Router free model de uu tien chi phi 0
OPENROUTER_MODEL=openrouter/free
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# ============================================================
# STORAGE — Cloudinary (Product Images)
# ============================================================
# Lấy từ: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Free tier: 25GB storage, 25GB bandwidth/month

# ============================================================
# EMAIL — Gmail SMTP via Nodemailer
# ============================================================
# Gmail account để gửi email
EMAIL_USER=your_email@gmail.com

# ⚠️ QUAN TRỌNG: Gmail App Password (KHÔNG phải password Gmail thường)
# Cách tạo: Google Account → Security → 2-Step Verification → App passwords
# → Select app: Mail → Select device: Other → Generate
# App Password có dạng: xxxx xxxx xxxx xxxx (16 chars, bỏ dấu cách khi dùng)
EMAIL_PASS=your_gmail_app_password_16_chars
